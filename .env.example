# ---- Database ----
# Leave DATABASE_URL UNSET to use the zero-setup embedded database (PGlite).
# Set it to run against a real PostgreSQL server (e.g. Docker):
# DATABASE_URL="postgresql://smartsme:smartsme@localhost:5432/smartsme"

# ---- Auth ----
# Any long random string. Used to sign session cookies.
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- Anthropic (optional) ----
# Without a key, the Smart Input Engine uses a built-in heuristic NLP parser.
# With a key, it upgrades to Claude for NLP + image OCR.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
